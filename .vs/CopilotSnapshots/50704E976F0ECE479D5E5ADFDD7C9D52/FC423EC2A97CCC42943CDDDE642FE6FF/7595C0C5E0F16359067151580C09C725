using System.Collections.Generic;
using System.Linq;
using UnityEngine;
using Utilities;
using View;
using Model.Runtime;

namespace UnitBrains.Player
{
    // Brain for a support unit that applies buffs instead of shooting.
    public class FourthUnitBrain : DefaultPlayerUnitBrain
    {
        // NOTE: change this string to match the new unit prefab's Name in the editor.
        public override string TargetUnitName => "Buff Unit";

        private enum BuffState { Idle, PrePause, PostPause }
        private BuffState _state = BuffState.Idle;
        private float _stateEndTime = 0f;

        // Interval between consecutive buffs (seconds)
        private readonly float _buffInterval = 4f;
        // Duration of applied buff
        private readonly float _buffDuration = 5f;
        // Pause length before and after buff
        private const float PauseLength = 0.5f;

        private float _nextBuffTime = 2f; // initial delay before first buff

        // This unit does not shoot
        public override List<Model.Runtime.Projectiles.BaseProjectile> GetProjectiles()
        {
            return new List<Model.Runtime.Projectiles.BaseProjectile>();
        }

        public override Vector2Int GetNextStep()
        {
            // If in pre/post pause — stay in place
            if (_state != BuffState.Idle)
                return unit.Pos;

            return base.GetNextStep();
        }

        public override void Update(float deltaTime, float time)
        {
            // state machine for pre-pause, buff action, post-pause
            if (_state == BuffState.Idle)
            {
                if (time >= _nextBuffTime)
                {
                    _state = BuffState.PrePause;
                    _stateEndTime = time + PauseLength;
                }
            }
            else if (_state == BuffState.PrePause)
            {
                if (time >= _stateEndTime)
                {
                    // perform buff attempt
                    TryApplyBuff();

                    // play VFX at our position (if registered)
                    if (ServiceLocator.Contains<VFXView>())
                    {
                        var vfx = ServiceLocator.Get<VFXView>();
                        vfx?.PlayVFX(unit.Pos, VFXView.VFXType.BuffApplied);
                    }

                    // enter post-pause
                    _state = BuffState.PostPause;
                    _stateEndTime = time + PauseLength;

                    // schedule next buff time
                    _nextBuffTime = time + _buffInterval;
                }
            }
            else if (_state == BuffState.PostPause)
            {
                if (time >= _stateEndTime)
                {
                    _state = BuffState.Idle;
                }
            }
        }

        private void TryApplyBuff()
        {
            // find allies in attack radius
            var allies = GetUnitsInRadius(unit.Config.AttackRange, enemies: false);
            if (allies == null || allies.Count == 0)
                return;

            // We'll try to find an ally without any (movement/attack) buff
            object targetUnit = null;

            var ibuffType = System.Type.GetType("Utilities.IBuffSystem");
            object ibuffObj = null;

            if (ibuffType != null && ServiceLocator.TryGet(ibuffType, out ibuffObj) && ibuffObj != null)
            {
                var getMove = ibuffType.GetMethod("GetMovementMultiplier");
                var getAttack = ibuffType.GetMethod("GetAttackMultiplier");

                foreach (var a in allies)
                {
                    // skip self
                    if (a == unit)
                        continue;

                    bool hasBuff = false;
                    if (getMove != null)
                    {
                        var mv = getMove.Invoke(ibuffObj, new object[] { a });
                        if (mv is float mvf && Mathf.Abs(mvf - 1f) > 0.0001f)
                            hasBuff = true;
                    }

                    if (!hasBuff && getAttack != null)
                    {
                        var at = getAttack.Invoke(ibuffObj, new object[] { a });
                        if (at is float atf && Mathf.Abs(atf - 1f) > 0.0001f)
                            hasBuff = true;
                    }

                    if (!hasBuff)
                    {
                        targetUnit = a;
                        break;
                    }
                }

                if (targetUnit != null)
                {
                    // Apply a speed buff (use AddSpeedBuff if available)
                    var addSpeed = ibuffType.GetMethod("AddSpeedBuff");
                    if (addSpeed != null)
                    {
                        addSpeed.Invoke(ibuffObj, new object[] { targetUnit, _buffDuration });
                        return;
                    }

                    // Fallback: call AddBuff with a constructed Buff via reflection if needed
                    var addBuff = ibuffType.GetMethod("AddBuff");
                    if (addBuff != null)
                    {
                        // Create Buff instance: Utilities.Buff
                        var buffType = System.Type.GetType("Utilities.Buff");
                        if (buffType != null)
                        {
                            var ctor = buffType.GetConstructor(new System.Type[] { typeof(float), typeof(float), typeof(float), typeof(string) });
                            if (ctor != null)
                            {
                                var buff = ctor.Invoke(new object[] { _buffDuration, 0.5f, 1f, "FourthUnitBuff" });
                                addBuff.Invoke(ibuffObj, new object[] { targetUnit, buff });
                            }
                        }
                    }
                }
            }
            else
            {
                // No buff system registered — do nothing
            }
        }
    }
}
